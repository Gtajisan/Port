# ╔══════════════════════════════════════════════════════╗
# ║         BAKA-CHAN BOT — INSTAGRAM EDITION            ║
# ║              Environment Configuration               ║
# ╚══════════════════════════════════════════════════════╝

# ═══════════════════════════════════════════════════════
#  AUTHENTICATION — choose ONE option below
# ═══════════════════════════════════════════════════════

# ─── Option 1 (RECOMMENDED for cloud hosting) ───────────
# Pre-export a session locally, then paste the base64 string here.
# Run this on your local machine:
#   node scripts/exportSession.js
# Then copy the printed value as IG_SESSION_STATE below.
# IG_SESSION_STATE=<base64 string from exportSession.js>

# ─── Option 2 (Direct login) ────────────────────────────
# Works well for VPS/local. May trigger Instagram 2FA on first run.
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password

# ─── Two-Factor Authentication ──────────────────────────
# If your account uses 2FA (TOTP), set your authenticator secret key here.
# Find it when you set up 2FA in Instagram → Settings → Two-Factor → Authenticator App
# IG_TOTP_SECRET=your_totp_base32_secret

# ═══════════════════════════════════════════════════════
#  BOT MODE
# ═══════════════════════════════════════════════════════
INSTAGRAM_MODE=true

# ═══════════════════════════════════════════════════════
#  BOT IDENTITY (matches config.json fields)
# ═══════════════════════════════════════════════════════
BOT_NAME=Baka-Chan
PREFIX=!
# Your Instagram numeric user ID — find it at:
#   https://www.instagram.com/web/search/topsearch/?query=your_username
#   or from the bot logs after first login
ADMIN_ID=your_instagram_numeric_user_id
BOT_VERSION=2.0.0
NODE_ENV=production

# ═══════════════════════════════════════════════════════
#  SESSION SECURITY
# ═══════════════════════════════════════════════════════
# AES-256-CBC encryption key for saved sessions on disk.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_this_to_random_256bit_key

# ═══════════════════════════════════════════════════════
#  OPTIONAL — PROXY
# ═══════════════════════════════════════════════════════
# Useful for residential IP rotation to avoid login blocks.
# IG_PROXY=http://user:pass@host:port

# ═══════════════════════════════════════════════════════
#  OPTIONAL — AI FEATURES
# ═══════════════════════════════════════════════════════
OPENAI_API_KEY=optional_leave_blank_if_unused
GEMINI_API_KEY=optional_leave_blank_if_unused

# ═══════════════════════════════════════════════════════
#  UPTIME / SELF-PING
# ═══════════════════════════════════════════════════════
# Set this to your hosted URL so the bot pings itself and stays awake.
# APP_URL=https://your-app-url.replit.app

# ═══════════════════════════════════════════════════════
#  RATE LIMITING
# ═══════════════════════════════════════════════════════
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# ═══════════════════════════════════════════════════════
#  LOGGING
# ═══════════════════════════════════════════════════════
LOG_LEVEL=info

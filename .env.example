# ╔══════════════════════════════════════════════════════╗
# ║         BAKA-CHAN BOT — INSTAGRAM EDITION            ║
# ║              Environment Configuration               ║
# ╚══════════════════════════════════════════════════════╝

# ─── Instagram Account Credentials ─────────────────────
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password

# ─── Bot Mode ───────────────────────────────────────────
# Set to "true" to run in Instagram mode, "false" for Facebook mode
INSTAGRAM_MODE=true

# ─── Bot Settings (matches config.json fields) ──────────
BOT_NAME=Baka-Chan
PREFIX=!
ADMIN_ID=your_instagram_numeric_user_id
BOT_VERSION=2.0.0
NODE_ENV=production

# ─── Session Security ───────────────────────────────────
# Generate a strong random key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_this_to_random_256bit_key

# ─── Optional Proxy ─────────────────────────────────────
# IG_PROXY=http://user:pass@host:port

# ─── Optional AI Features ───────────────────────────────
OPENAI_API_KEY=optional_leave_blank_if_unused
GEMINI_API_KEY=optional_leave_blank_if_unused

# ─── App Uptime (Self-ping URL for hosting) ─────────────
# APP_URL=https://your-app-url.replit.app

# ─── Rate Limiting ──────────────────────────────────────
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# ─── Logging ────────────────────────────────────────────
LOG_LEVEL=info
